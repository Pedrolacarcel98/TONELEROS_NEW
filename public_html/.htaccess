<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Forzar HTTPS (Recomendado en Hostinger)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Redirigir llamadas de API al backend de Python
  # Esto le dice a Apache que todo lo que empiece por /api pase por el proceso de Python
  RewriteCond %{REQUEST_URI} ^/api
  RewriteRule ^api/(.*)$ http://localhost:8000/api/$1 [P,L]

  # 3. Rutas para React (SPA)
  # Si el archivo o carpeta no existen físicamente, mándalo al index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
